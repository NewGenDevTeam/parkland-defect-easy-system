// Parkland Defect Easy System — simple floor-plan based defect tracking.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MAIN_CON
  SUB_CON
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
}

enum DefectStatus {
  NEW // created by main-con, no sub-con assigned yet
  ASSIGNED // assigned to a sub-con
  IN_PROGRESS // sub-con is working on it
  COMPLETED // sub-con marked done, waiting for review
  CLOSED // main-con verified and closed
  REOPENED // main-con rejected the fix, sent back to sub-con
}

enum PhotoType {
  DEFECT // photo of the problem (uploaded by main-con)
  COMPLETION // proof of fix (uploaded by sub-con)
}

enum MediaType {
  IMAGE
  VIDEO // short video evidence, uploaded alongside photos
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         Role
  createdAt    DateTime @default(now())

  // Sub-Con profile (Phase 5). Inactive accounts cannot log in and are hidden
  // from new assignment dropdowns; history stays intact (never hard-delete).
  companyName String?
  department  String? // trade, e.g. Plumbing, Tiling, Electrical
  phone       String?
  active      Boolean @default(true)

  // Self-relation: one MAIN_CON manages many SUB_CON accounts.
  mainConId      String?
  mainCon        User?   @relation("ManagedSubCons", fields: [mainConId], references: [id])
  managedSubCons User[]  @relation("ManagedSubCons")

  ownedProjects   Project[] @relation("ProjectOwner")
  assignedDefects Defect[]  @relation("AssignedSubCon")
  createdDefects  Defect[]  @relation("DefectCreator")
  // Defect Types that preselect this Sub-Con in the Quick Add form.
  defaultForDefectTypes DefectType[] @relation("DefectTypeDefaultSubCon")

  @@index([mainConId])
}

model Project {
  id          String        @id @default(cuid())
  name        String
  location    String?
  description String?
  status      ProjectStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())

  ownerId String
  owner   User   @relation("ProjectOwner", fields: [ownerId], references: [id])

  drawings    Drawing[]
  defects     Defect[]
  defectTypes DefectType[]
}

model Drawing {
  id        String   @id @default(cuid())
  name      String
  imageUrl  String
  // At most one Master Layout per project (overview plan used to pick a
  // Unit/Floor Layout). Defects are registered on unit layouts.
  isMaster  Boolean  @default(false)
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  defects Defect[]
}

// Project-scoped, pre-registered defect names shown in the Quick Add dropdown
// (Crack, Water Leakage, …). Maintained by the Main-Con; rows are deactivated,
// never deleted, so existing defects keep their reference for reporting.
model DefectType {
  id        String   @id @default(cuid())
  name      String
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  // The "Others" row: selecting it reveals a short custom defect name field.
  isOthers  Boolean  @default(false)
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Optional default Sub-Con/Trade preselected when this type is chosen.
  defaultSubConId String?
  defaultSubCon   User?   @relation("DefectTypeDefaultSubCon", fields: [defaultSubConId], references: [id])

  defects Defect[]

  @@index([projectId])
}

model Defect {
  id          String       @id @default(cuid())
  // Display name: the DefectType name, or the custom defect name when the
  // "Others" type is selected. Kept alongside defectTypeId for compatibility.
  title       String
  description String?
  trade       String? // trade / category, e.g. Plumbing, Electrical
  priority    Priority     @default(MEDIUM)
  status      DefectStatus @default(NEW)
  reopenReason String? // short note from main-con when a fix is reopened
  x           Float // horizontal pin position on the drawing (0-1 ratio)
  y           Float // vertical pin position on the drawing (0-1 ratio)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  drawingId String
  drawing   Drawing @relation(fields: [drawingId], references: [id], onDelete: Cascade)

  // Structured defect classification (nullable so legacy rows stay valid;
  // the backfill script links every existing defect to a type).
  defectTypeId String?
  defectType   DefectType? @relation(fields: [defectTypeId], references: [id])

  createdById String
  createdBy   User   @relation("DefectCreator", fields: [createdById], references: [id])

  assignedToId String?
  assignedTo   User?   @relation("AssignedSubCon", fields: [assignedToId], references: [id])

  photos Photo[]

  @@index([projectId])
  @@index([assignedToId])
  @@index([defectTypeId])
}

model Photo {
  id        String    @id @default(cuid())
  // Images: /uploads/<name>. Videos: /uploads/videos/<defectId>/<name>
  // (served with HTTP Range support so players can seek).
  url       String
  type      PhotoType @default(DEFECT)
  // Whether the stored file is an image or a short video. Defaults to IMAGE
  // so every existing photo row keeps working unchanged.
  media     MediaType @default(IMAGE)
  createdAt DateTime  @default(now())

  defectId String
  defect   Defect @relation(fields: [defectId], references: [id], onDelete: Cascade)

  @@index([defectId])
}
